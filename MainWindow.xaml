<Window x:Class="ProgettoLavoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tris" Height="650" Width="550"
        Background="#1A2B3C">
    <Window.Resources>
        <!-- Stile per i Pulsanti della Griglia -->
        <Style TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2C3E50" Offset="0"/>
                        <GradientStop Color="#34495E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#4A627A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="70"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Direction="320" ShadowDepth="5" BlurRadius="10" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#5DADE2"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#5DADE2" Direction="320" ShadowDepth="7" BlurRadius="15" Opacity="0.7"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stile per il Pulsante Nuova Partita -->
        <Style x:Key="StilePulsanteNuovaPartita" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#28A745" Offset="0"/>
                        <GradientStop Color="#34D058" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="18,10"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#34D058" Direction="320" ShadowDepth="6" BlurRadius="12" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="pulsante0_0" Grid.Row="0" Grid.Column="0" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante0_1" Grid.Row="0" Grid.Column="1" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante0_2" Grid.Row="0" Grid.Column="2" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante1_0" Grid.Row="1" Grid.Column="0" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante1_1" Grid.Row="1" Grid.Column="1" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante1_2" Grid.Row="1" Grid.Column="2" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante2_0" Grid.Row="2" Grid.Column="0" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante2_1" Grid.Row="2" Grid.Column="1" Click="GestisciClickPulsante"/>
        <Button x:Name="pulsante2_2" Grid.Row="2" Grid.Column="2" Click="GestisciClickPulsante"/>

        <TextBlock x:Name="testoStatoGioco" Grid.Row="3" Grid.ColumnSpan="3" FontSize="28" FontWeight="Bold" Foreground="#BBDEFB" TextAlignment="Center" Margin="15"/>
        <Button x:Name="pulsanteNuovaPartita" Grid.Row="4" Grid.ColumnSpan="3" Content="Nuova Partita" Click="AvviaNuovaPartita" Style="{StaticResource StilePulsanteNuovaPartita}"/>
    </Grid>
</Window>
